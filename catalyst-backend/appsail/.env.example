# Zoho Catalyst Configuration
# These are set automatically by Catalyst runtime, but can be overridden for local dev
CATALYST_PROJECT_ID=36873000000031001
CATALYST_ENVIRONMENT=Development

# Cloudflare Workers AI (Meta Llama 3)
CF_ACCOUNT_ID=your_cloudflare_account_id_here
CF_API_TOKEN=your_cloudflare_api_token_here

# Frontend Origin (for CORS)
FRONTEND_ORIGIN=http://localhost:3000

# Processing Defaults
DEFAULT_WALL_HEIGHT_M=2.7
DEFAULT_WALL_THICKNESS_M=0.15
