{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spatialforge.io/schemas/spatial-model/v1",
  "title": "SpatialForge Unified Spatial Model",
  "description": "The canonical internal representation of an indoor space. All input formats are normalized into this schema before 3D generation.",
  "type": "object",
  "required": ["version", "metadata", "floors"],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Schema version"
    },
    "metadata": {
      "type": "object",
      "required": ["project_id", "created_at", "coordinate_system"],
      "properties": {
        "project_id": { "type": "string", "format": "uuid" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "file_id": { "type": "string", "format": "uuid" },
              "type": { "type": "string" },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
              "contribution": {
                "type": "string",
                "description": "What this source contributed (walls, dimensions, etc.)"
              }
            }
          }
        },
        "coordinate_system": {
          "type": "object",
          "properties": {
            "units": { "type": "string", "enum": ["meters", "feet"], "default": "meters" },
            "origin": {
              "type": "object",
              "description": "Origin point (typically bottom-left of bounding box)",
              "properties": {
                "x": { "type": "number" },
                "y": { "type": "number" },
                "z": { "type": "number", "default": 0 }
              }
            },
            "up_axis": { "type": "string", "enum": ["Y", "Z"], "default": "Y" }
          }
        },
        "bounding_box": {
          "type": "object",
          "properties": {
            "min": { "$ref": "#/$defs/Point3D" },
            "max": { "$ref": "#/$defs/Point3D" }
          }
        },
        "total_area_sqm": { "type": "number" },
        "building_type": { "type": "string" }
      }
    },
    "floors": {
      "type": "array",
      "description": "Array of floor levels, each containing its own spatial data",
      "items": {
        "$ref": "#/$defs/Floor"
      }
    },
    "inter_floor_elements": {
      "type": "array",
      "description": "Elements spanning multiple floors (stairs, elevators)",
      "items": {
        "$ref": "#/$defs/InterFloorElement"
      }
    }
  },
  "$defs": {
    "Point2D": {
      "type": "object",
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    },
    "Point3D": {
      "type": "object",
      "required": ["x", "y", "z"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "z": { "type": "number" }
      }
    },
    "Polygon2D": {
      "type": "object",
      "description": "A closed polygon defined by ordered vertices",
      "properties": {
        "vertices": {
          "type": "array",
          "items": { "$ref": "#/$defs/Point2D" },
          "minItems": 3
        },
        "holes": {
          "type": "array",
          "description": "Interior holes (e.g., for atriums)",
          "items": {
            "type": "array",
            "items": { "$ref": "#/$defs/Point2D" }
          }
        }
      }
    },
    "Floor": {
      "type": "object",
      "required": ["level", "walls", "rooms"],
      "properties": {
        "level": {
          "type": "integer",
          "description": "Floor number (0 = ground, negative = basement)"
        },
        "label": { "type": "string", "description": "Display name, e.g. 'Ground Floor'" },
        "elevation_m": { "type": "number", "description": "Floor elevation from ground level" },
        "height_m": { "type": "number", "default": 2.7, "description": "Floor-to-ceiling height" },
        "walls": {
          "type": "array",
          "items": { "$ref": "#/$defs/Wall" }
        },
        "rooms": {
          "type": "array",
          "items": { "$ref": "#/$defs/Room" }
        },
        "doors": {
          "type": "array",
          "items": { "$ref": "#/$defs/Door" }
        },
        "windows": {
          "type": "array",
          "items": { "$ref": "#/$defs/Window" }
        },
        "columns": {
          "type": "array",
          "items": { "$ref": "#/$defs/Column" }
        },
        "annotations": {
          "type": "array",
          "items": { "$ref": "#/$defs/Annotation" }
        }
      }
    },
    "Wall": {
      "type": "object",
      "required": ["id", "start", "end"],
      "properties": {
        "id": { "type": "string" },
        "start": { "$ref": "#/$defs/Point2D" },
        "end": { "$ref": "#/$defs/Point2D" },
        "thickness_m": { "type": "number", "default": 0.15 },
        "height_m": {
          "type": "number",
          "description": "Override height for this wall (e.g., half-walls)"
        },
        "type": {
          "type": "string",
          "enum": ["exterior", "interior", "partition", "curtain", "retaining", "unknown"],
          "default": "unknown"
        },
        "material": {
          "type": "string",
          "enum": ["concrete", "brick", "drywall", "glass", "wood", "metal", "stone", "unknown"],
          "default": "unknown"
        },
        "openings": {
          "type": "array",
          "description": "References to doors/windows in this wall",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["door", "window"] },
              "ref_id": { "type": "string" }
            }
          }
        },
        "connected_walls": {
          "type": "array",
          "description": "IDs of walls connected at junctions",
          "items": { "type": "string" }
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "source": { "type": "string", "description": "Which input source detected this wall" }
      }
    },
    "Room": {
      "type": "object",
      "required": ["id", "polygon"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string", "description": "Room name, e.g. 'Master Bedroom'" },
        "type": {
          "type": "string",
          "enum": [
            "living_room", "bedroom", "kitchen", "bathroom", "toilet",
            "dining_room", "hallway", "corridor", "closet", "storage",
            "laundry", "garage", "balcony", "terrace", "office",
            "study", "library", "gym", "pool", "stairwell",
            "elevator_lobby", "reception", "conference_room", "server_room",
            "mechanical", "utility", "unknown"
          ],
          "default": "unknown"
        },
        "polygon": { "$ref": "#/$defs/Polygon2D" },
        "area_sqm": { "type": "number" },
        "perimeter_m": { "type": "number" },
        "ceiling_height_m": { "type": "number" },
        "floor_material": { "type": "string" },
        "wall_ids": {
          "type": "array",
          "items": { "type": "string" },
          "description": "IDs of walls bounding this room"
        },
        "door_ids": { "type": "array", "items": { "type": "string" } },
        "window_ids": { "type": "array", "items": { "type": "string" } },
        "connected_rooms": {
          "type": "array",
          "description": "Rooms accessible from this room via doors",
          "items": {
            "type": "object",
            "properties": {
              "room_id": { "type": "string" },
              "via_door_id": { "type": "string" }
            }
          }
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "Door": {
      "type": "object",
      "required": ["id", "position", "width_m"],
      "properties": {
        "id": { "type": "string" },
        "position": { "$ref": "#/$defs/Point2D" },
        "width_m": { "type": "number", "default": 0.9 },
        "height_m": { "type": "number", "default": 2.1 },
        "type": {
          "type": "string",
          "enum": ["single_swing", "double_swing", "sliding", "pocket", "bi_fold", "revolving", "french", "opening_no_door", "unknown"],
          "default": "unknown"
        },
        "swing_direction": {
          "type": "string",
          "enum": ["inward", "outward", "left", "right", "both", "none"],
          "description": "Direction the door opens"
        },
        "wall_id": { "type": "string", "description": "ID of the wall this door is in" },
        "position_along_wall": {
          "type": "number",
          "description": "Distance from wall start to door center, in meters"
        },
        "connects_rooms": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 2,
          "description": "IDs of rooms this door connects"
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "Window": {
      "type": "object",
      "required": ["id", "position", "width_m"],
      "properties": {
        "id": { "type": "string" },
        "position": { "$ref": "#/$defs/Point2D" },
        "width_m": { "type": "number", "default": 1.2 },
        "height_m": { "type": "number", "default": 1.2 },
        "sill_height_m": { "type": "number", "default": 0.9 },
        "type": {
          "type": "string",
          "enum": ["single", "double", "sliding", "casement", "fixed", "bay", "skylight", "unknown"],
          "default": "unknown"
        },
        "wall_id": { "type": "string" },
        "position_along_wall": { "type": "number" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "Column": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "position": { "$ref": "#/$defs/Point2D" },
        "shape": { "type": "string", "enum": ["rectangular", "circular", "L_shaped"] },
        "width_m": { "type": "number" },
        "depth_m": { "type": "number" },
        "radius_m": { "type": "number", "description": "For circular columns" }
      }
    },
    "InterFloorElement": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["staircase", "elevator", "escalator", "ramp", "void"] },
        "floors": {
          "type": "array",
          "items": { "type": "integer" },
          "description": "Floor levels this element connects"
        },
        "polygon": { "$ref": "#/$defs/Polygon2D" },
        "direction": { "type": "string", "enum": ["up", "down", "both"] }
      }
    },
    "Annotation": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["dimension", "label", "note", "area"] },
        "position": { "$ref": "#/$defs/Point2D" },
        "text": { "type": "string" },
        "value_m": { "type": "number", "description": "Numeric value for dimension annotations" }
      }
    }
  }
}
