# ===================================================
# Maptix 3D Backend - Environment Configuration
# ===================================================

# --- Mode ---
ENVIRONMENT=development
DEBUG=true

# --- Authentication Provider ---
# "jwt"      = Local bcrypt + JWT (default, works out of the box)
# "catalyst" = Zoho Catalyst REST API (needs CATALYST_* vars below)
AUTH_PROVIDER=jwt

# --- Catalyst Auth (only needed when AUTH_PROVIDER=catalyst) ---
# Get these from: https://console.catalyst.zoho.com -> Your Project -> Settings
CATALYST_PROJECT_ID=
CATALYST_PROJECT_KEY=
CATALYST_PROJECT_DOMAIN=
CATALYST_ENVIRONMENT=Development

# --- JWT (only needed when AUTH_PROVIDER=jwt in production) ---
# In development, a random secret is auto-generated. In production, set this:
# JWT_SECRET=your-super-secret-random-string-here

# --- Cloudflare Workers AI ---
CF_ACCOUNT_ID=
CF_API_TOKEN=

# --- CORS (comma-separated origins) ---
# CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
